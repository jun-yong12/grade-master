<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.ac.tukorea.grade.mapper.StudentMapper">

    <!-- 결과 매핑 -->
    <resultMap id="StudentResultMap" type="StudentDTO">
        <id     property="id"            column="id"/>
        <result property="studentNumber" column="student_number"/>
        <result property="name"          column="name"/>
        <result property="grade"         column="grade"/>
        <result property="department"    column="department"/>
        <result property="phone"         column="phone"/>
        <result property="email"         column="email"/>
        <result property="status"        column="status"/>
        <result property="average"       column="average"/>
    </resultMap>

    <!-- 검색/필터 조건 -->
    <sql id="searchCondition">
        <if test="page.keyword != null and page.keyword != ''">
            <choose>
                <when test="page.searchType == 'studentNumber'">
                    AND s.student_number LIKE CONCAT('%', #{page.keyword}, '%')
                </when>
                <otherwise>
                    AND s.name LIKE CONCAT('%', #{page.keyword}, '%')
                </otherwise>
            </choose>
        </if>
        <if test="page.filterDept != null and page.filterDept != ''">
            AND s.department = #{page.filterDept}
        </if>
        <if test="page.filterGrade != null and page.filterGrade != ''">
            AND s.grade = #{page.filterGrade}
        </if>
        <if test="page.filterStatus != null and page.filterStatus != ''">
            AND s.status = #{page.filterStatus}
        </if>
    </sql>

    <!-- 전체 목록 (페이징 + 검색 + 정렬 + 평균) -->
    <select id="findAll" resultMap="StudentResultMap">
        SELECT s.*,
               ROUND(AVG(g.score), 1) AS average
        FROM students s
        LEFT JOIN grades g ON s.id = g.student_id
        WHERE 1=1
        <include refid="searchCondition"/>
        GROUP BY s.id
        ORDER BY
        <choose>
            <when test="page.sortField == 'name'">s.name</when>
            <when test="page.sortField == 'average'">average</when>
            <otherwise>s.student_number</otherwise>
        </choose>
        <choose>
            <when test="page.sortDir == 'DESC'">DESC</when>
            <otherwise>ASC</otherwise>
        </choose>
        LIMIT #{page.size} OFFSET #{page.offset}
    </select>

    <!-- 전체 건수 -->
    <select id="countAll" resultType="long">
        SELECT COUNT(*) FROM students s
        WHERE 1=1
        <include refid="searchCondition"/>
    </select>

    <!-- 단건 조회 -->
    <select id="findById" resultMap="StudentResultMap">
        SELECT s.*, ROUND(AVG(g.score), 1) AS average
        FROM students s
        LEFT JOIN grades g ON s.id = g.student_id
        WHERE s.id = #{id}
        GROUP BY s.id
    </select>

    <!-- 과별 학생 목록 -->
    <select id="findByDepartment" resultMap="StudentResultMap">
        SELECT * FROM students WHERE department = #{department} ORDER BY student_number
    </select>

    <!-- 필터 적용 전체 조회 (엑셀 내보내기용, 페이징 없음) -->
    <select id="findAllNoLimit" resultMap="StudentResultMap">
        SELECT s.*, ROUND(AVG(g.score), 1) AS average
        FROM students s
        LEFT JOIN grades g ON s.id = g.student_id
        WHERE 1=1
        <include refid="searchCondition"/>
        GROUP BY s.id
        ORDER BY
        <choose>
            <when test="page.sortField == 'name'">s.name</when>
            <when test="page.sortField == 'average'">average</when>
            <otherwise>s.student_number</otherwise>
        </choose>
        <choose>
            <when test="page.sortDir == 'DESC'">DESC</when>
            <otherwise>ASC</otherwise>
        </choose>
    </select>

    <!-- 학과 목록 (필터 드롭다운용) -->
    <select id="findDistinctDepartments" resultType="string">
        SELECT DISTINCT department FROM students WHERE department IS NOT NULL ORDER BY department
    </select>

    <!-- 학번으로 조회 -->
    <select id="findByStudentNumber" resultMap="StudentResultMap">
        SELECT * FROM students WHERE student_number = #{studentNumber}
    </select>

    <!-- 학번 존재 여부 -->
    <select id="existsByStudentNumber" resultType="boolean">
        SELECT COUNT(*) > 0 FROM students WHERE student_number = #{studentNumber}
    </select>

    <!-- 등록 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO students (student_number, name, grade, department, phone, email, status)
        VALUES (#{studentNumber}, #{name}, #{grade}, #{department}, #{phone}, #{email}, #{status})
    </insert>

    <!-- 수정 -->
    <update id="update">
        UPDATE students
        SET student_number = #{studentNumber},
            name           = #{name},
            grade          = #{grade},
            department     = #{department},
            phone          = #{phone},
            email          = #{email},
            status         = #{status}
        WHERE id = #{id}
    </update>

    <!-- 삭제 -->
    <delete id="deleteById">
        DELETE FROM students WHERE id = #{id}
    </delete>

    <!-- 과 내 등수 계산 (나보다 평균이 높은 학생 수 + 1) -->
    <select id="countRank" resultType="int">
        SELECT COUNT(*) + 1
        FROM students s
        JOIN (
            SELECT student_id, AVG(score) AS avg_score
            FROM grades
            WHERE semester = #{semester}
            GROUP BY student_id
        ) g ON s.id = g.student_id
        WHERE s.grade = (SELECT grade FROM students WHERE id = #{studentId})
          AND s.department = (SELECT department FROM students WHERE id = #{studentId})
          AND g.avg_score > (
              SELECT COALESCE(AVG(score), 0)
              FROM grades
              WHERE student_id = #{studentId} AND semester = #{semester}
          )
    </select>

</mapper>
